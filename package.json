{
  "name": "guardian",
  "version": "1.0.0-beta",
  "description": "Run any command under transparent network interception.",
  "type": "module",
  "scripts": {
    "smoke": "node --import tsx ./node_modules/zx/build/cli.js scripts/smoke.zx.ts",
    "test": "npm run smoke",
    "test:bypass": "node --test scripts/connect-bypass.test.ts",
    "test:handshake": "node --test scripts/connect-handshake.test.ts",
    "coverage": "node --import tsx ./node_modules/zx/build/cli.js scripts/coverage.zx.ts",
    "pack:release": "node --import tsx ./node_modules/zx/build/cli.js scripts/pack-release.zx.ts",
    "format:js": "biome format --write",
    "format:rs": "cargo fmt",
    "format": "npm-run-all --parallel format:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sparse-Dynamix/guardian.git"
  },
  "keywords": [],
  "author": "Sepehr Laal",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/Sparse-Dynamix/guardian/issues"
  },
  "homepage": "https://github.com/Sparse-Dynamix/guardian#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@fastify/sse": "^0.4.0",
    "@fastify/websocket": "^11.2.0",
    "@types/archiver": "^8.0.0",
    "@types/node": "^25.9.1",
    "archiver": "^8.0.0",
    "fastify": "^5.8.5",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.22.4",
    "zx": "^8.8.5"
  }
}
