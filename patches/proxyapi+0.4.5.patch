+fn is_protocol_upgrade_response<B>(res: &Response<B>) -> bool {
+    res.status() == hyper::StatusCode::SWITCHING_PROTOCOLS
+        || res.headers().get(UPGRADE).is_some()
+}
+
 pub(crate) fn sanitize_response_for_client<B>(res: &mut Response<B>, version: hyper::Version) {
     if version == hyper::Version::HTTP_2 {
         sanitize_response_for_http2(res);
+    } else if version == hyper::Version::HTTP_11 && !is_protocol_upgrade_response(res) {
+        // MITM clients often stall when upstream keep-alive outlives the intercepted TLS session.
+        res.headers_mut().insert(
+            CONNECTION,
+            http::HeaderValue::from_static("close"),
+        );
+        res.headers_mut().remove(KEEP_ALIVE);
     }
 }
 
