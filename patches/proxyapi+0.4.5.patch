+struct FilteredStreamBody<B> {
+    inner: Pin<Box<B>>,
+    filter: Arc<dyn ContentFilter>,
+    method: String,
+    url: String,
+    scheme: String,
+    status: u16,
+    sse_mode: bool,
+    pending: BytesMut,
+    current_unit: Option<Bytes>,
+    filter_result: Arc<Mutex<Option<FilterVerdict>>>,
+    filter_done: Arc<AtomicBool>,
+    filtering: bool,
+    outbox: VecDeque<Bytes>,
+    upstream_done: bool,
+    stream_done: bool,
+}
+
+impl<B> FilteredStreamBody<B> {
+    fn new(
+        body: B,
+        filter: Arc<dyn ContentFilter>,
+        method: String,
+        url: String,
+        scheme: String,
+        status: u16,
+        sse_mode: bool,
+    ) -> Self {
+        Self {
+            inner: Box::pin(body),
+            filter,
+            method,
+            url,
+            scheme,
+            status,
+            sse_mode,
+            pending: BytesMut::new(),
+            current_unit: None,
+            filter_result: Arc::new(Mutex::new(None)),
+            filter_done: Arc::new(AtomicBool::new(false)),
+            filtering: false,
+            outbox: VecDeque::new(),
+            upstream_done: false,
+            stream_done: false,
+        }
+    }
+
+    fn start_filter(&mut self, unit: Bytes) {
+        let filter = Arc::clone(&self.filter);
+        let method = self.method.clone();
+        let url = self.url.clone();
+        let scheme = self.scheme.clone();
+        let status = self.status;
+        let result = Arc::clone(&self.filter_result);
+        let done = Arc::clone(&self.filter_done);
+        self.current_unit = Some(unit.clone());
+        self.filtering = true;
+        self.filter_done.store(false, Ordering::Release);
+        *self.filter_result.lock().unwrap_or_else(|e| e.into_inner()) = None;
+        tokio::spawn(async move {
+            let verdict = filter
+                .check_http_response(HttpFilterContext {
+                    method: &method,
+                    url: &url,
+                    status,
+                    scheme: &scheme,
+                    body: &unit,
+                })
+                .await;
+            *result.lock().unwrap_or_else(|e| e.into_inner()) = Some(verdict);
+            done.store(true, Ordering::Release);
+        });
+    }
+
+    fn poll_filter(&mut self, cx: &mut Context<'_>) -> Poll<()> {
+        if !self.filtering {
+            return Poll::Ready(());
+        }
+        if self.filter_done.load(Ordering::Acquire) {
+            return Poll::Ready(());
+        }
+        cx.waker().wake_by_ref();
+        Poll::Pending
+    }
+
+    fn take_filter_verdict(&mut self) -> Option<FilterVerdict> {
+        if !self.filtering {
+            return None;
+        }
+        if !self.filter_done.load(Ordering::Acquire) {
+            return None;
+        }
+        self.filtering = false;
+        self.filter_result
+            .lock()
+            .unwrap_or_else(|e| e.into_inner())
+            .take()
+    }
+
+    fn take_sse_unit(pending: &mut BytesMut) -> Option<Bytes> {
+        let buf = pending.as_ref();
+        let pos = buf.windows(2).position(|window| window == b"\n\n")?;
+        Some(pending.split_to(pos + 2).freeze())
+    }
+
+    fn flush_pending(&mut self) -> bool {
+        if self.pending.is_empty() {
+            return false;
+        }
+        let unit = self.pending.split().freeze();
+        self.start_filter(unit);
+        true
+    }
+}
+
+impl<B> Unpin for FilteredStreamBody<B> {}
+
+impl<B> HttpBody for FilteredStreamBody<B>
+where
+    B: HttpBody<Data = Bytes, Error = hyper::Error>,
+{
+    type Data = Bytes;
+    type Error = hyper::Error;
+
+    fn poll_frame(
+        self: Pin<&mut Self>,
+        cx: &mut Context<'_>,
+    ) -> Poll<Option<Result<Frame<Self::Data>, Self::Error>>> {
+        let this = self.get_mut();
+
+        loop {
+            if let Some(chunk) = this.outbox.pop_front() {
+                return Poll::Ready(Some(Ok(Frame::data(chunk))));
+            }
+            if this.stream_done {
+                return Poll::Ready(None);
+            }
+
+            if this.filtering {
+                match this.poll_filter(cx) {
+                    Poll::Ready(()) => {
+                        let Some(verdict) = this.take_filter_verdict() else {
+                            return Poll::Pending;
+                        };
+                        match verdict {
+                            FilterVerdict::Allow => {
+                                if let Some(unit) = this.current_unit.take() {
+                                    this.outbox.push_back(unit);
+                                }
+                            }
+                            FilterVerdict::Replace { body, .. } => {
+                                this.current_unit = None;
+                                this.outbox.push_back(body);
+                            }
+                            FilterVerdict::Block { message } => {
+                                this.current_unit = None;
+                                this.outbox.push_back(message);
+                                this.stream_done = true;
+                            }
+                        }
+                        continue;
+                    }
+                    Poll::Pending => return Poll::Pending,
+                }
+            }
+
+            if this.sse_mode {
+                if let Some(unit) = Self::take_sse_unit(&mut this.pending) {
+                    this.start_filter(unit);
+                    continue;
+                }
+            } else if !this.pending.is_empty() {
+                let unit = this.pending.split().freeze();
+                this.start_filter(unit);
+                continue;
+            }
+
+            if this.upstream_done {
+                if this.flush_pending() {
+                    continue;
+                }
+                this.stream_done = true;
+                return Poll::Ready(None);
+            }
+
+            match this.inner.as_mut().poll_frame(cx) {
+                Poll::Ready(Some(Ok(frame))) => {
+                    if let Some(data) = frame.data_ref() {
+                        this.pending.extend_from_slice(data);
+                        if this.sse_mode {
+                            if let Some(unit) = Self::take_sse_unit(&mut this.pending) {
+                                this.start_filter(unit);
+                                continue;
+                            }
+                        } else {
+                            let unit = this.pending.split().freeze();
+                            this.start_filter(unit);
+                            continue;
+                        }
+                    }
+                    if this.inner.is_end_stream() {
+                        this.upstream_done = true;
+                    }
+                }
+                Poll::Ready(Some(Err(e))) => return Poll::Ready(Some(Err(e))),
+                Poll::Ready(None) => {
+                    this.upstream_done = true;
+                }
+                Poll::Pending => return Poll::Pending,
+            }
+        }
+    }
+
+    fn is_end_stream(&self) -> bool {
+        self.stream_done
+            && self.outbox.is_empty()
+            && !self.filtering
+            && self.pending.is_empty()
+    }
+
+    fn size_hint(&self) -> SizeHint {
+        self.inner.size_hint()
+    }
+}
+
+pub(crate) fn filtered_stream<B>(
+    body: B,
+    filter: Arc<dyn ContentFilter>,
+    method: String,
+    url: String,
+    scheme: String,
+    status: u16,
+    sse_mode: bool,
+) -> ProxyBody
+where
+    B: HttpBody<Data = Bytes, Error = hyper::Error> + Send + Sync + 'static,
+{
+    FilteredStreamBody::new(body, filter, method, url, scheme, status, sse_mode).boxed()
+}
