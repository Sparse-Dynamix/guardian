@@ -0,0 +1,34 @@
+//! Optional response/frame filtering hook for MITM proxies.
+
+use async_trait::async_trait;
+use bytes::Bytes;
+
+/// Context for filtering an HTTP response before it reaches the client.
+pub struct HttpFilterContext<'a> {
+    pub method: &'a str,
+    pub url: &'a str,
+    pub status: u16,
+    pub scheme: &'a str,
+    pub body: &'a [u8],
+}
+
+/// Context for filtering a WebSocket frame before it reaches the client.
+pub struct WsFilterContext<'a> {
+    pub direction: &'a str,
+    pub opcode: &'a str,
+    pub payload: &'a [u8],
+}
+
+/// Result of a content safety check.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum FilterVerdict {
+    Allow,
+    Block { message: Bytes },
+}
+
+/// Async hook invoked after upstream content is captured and before the client sees it.
+#[async_trait]
+pub trait ContentFilter: Send + Sync {
+    async fn check_http_response(&self, ctx: HttpFilterContext<'_>) -> FilterVerdict;
+    async fn check_ws_frame(&self, ctx: WsFilterContext<'_>) -> FilterVerdict;
+}
