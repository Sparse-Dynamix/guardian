+fn is_literal_ip(host: &str) -> bool {
+    host.parse::<std::net::IpAddr>().is_ok()
+}
+
+/// When synthetic CONNECT uses a resolved IP, mint the MITM cert from TLS SNI instead.
+fn mitm_cert_authority(connect_authority: &Authority, client_hello: &[u8]) -> Authority {
+    if !is_literal_ip(connect_authority.host()) {
+        return connect_authority.clone();
+    }
+    let Some(host) = sni_host_from_client_hello(client_hello) else {
+        return connect_authority.clone();
+    };
+    let port = connect_authority.port_u16().unwrap_or(443);
+    Authority::try_from(format!("{}:{}", host, port)).unwrap_or_else(|_| {
+        tracing::debug!("Ignoring invalid ClientHello SNI host {host:?}");
+        connect_authority.clone()
+    })
+}
+
+fn sni_host_from_client_hello(data: &[u8]) -> Option<String> {
+    if data.len() < 9 || data[0] != TLS_RECORD_HANDSHAKE || data[5] != 0x01 {
+        return None;
+    }
+
+    let mut pos = 9usize; // ClientHello body: version + random
+    if data.len() < pos + 2 + 32 + 1 {
+        return None;
+    }
+    pos += 2 + 32; // version + random
+    let session_id_len = data[pos] as usize;
+    pos += 1 + session_id_len;
+    if data.len() < pos + 2 {
+        return None;
+    }
+    let cipher_suites_len = u16::from_be_bytes([data[pos], data[pos + 1]]) as usize;
+    pos += 2 + cipher_suites_len;
+    if data.len() < pos + 1 {
+        return None;
+    }
+    let comp_len = data[pos] as usize;
+    pos += 1 + comp_len;
+    if data.len() < pos + 2 {
+        return None;
+    }
+    let ext_len = u16::from_be_bytes([data[pos], data[pos + 1]]) as usize;
+    pos += 2;
+    let ext_end = pos.saturating_add(ext_len);
+    if ext_end > data.len() {
+        return None;
+    }
+
+    while pos + 4 <= ext_end {
+        let ext_type = u16::from_be_bytes([data[pos], data[pos + 1]]);
+        let ext_data_len = u16::from_be_bytes([data[pos + 2], data[pos + 3]]) as usize;
+        pos += 4;
+        if pos + ext_data_len > ext_end {
+            break;
+        }
+        if ext_type == 0 {
+            let ext = &data[pos..pos + ext_data_len];
+            if ext.len() >= 2 {
+                let list_len = u16::from_be_bytes([ext[0], ext[1]]) as usize;
+                let mut spos = 2usize;
+                let list_end = 2 + list_len;
+                while spos + 3 <= list_end && spos + 3 <= ext.len() {
+                    let name_type = ext[spos];
+                    let name_len = u16::from_be_bytes([ext[spos + 1], ext[spos + 2]]) as usize;
+                    spos += 3;
+                    if name_type == 0 && spos + name_len <= ext.len() {
+                        return std::str::from_utf8(&ext[spos..spos + name_len])
+                            .ok()
+                            .map(str::to_owned);
+                    }
+                    spos += name_len;
+                }
+            }
+        }
+        pos += ext_data_len;
+    }
+
+    None
+}
+
 fn is_h2_preface(buffered: &[u8]) -> bool {
     buffered == H2_PREFACE
 }
