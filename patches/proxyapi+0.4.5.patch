+fn is_sse_response(parts: &http::response::Parts) -> bool {
+    parts
+        .headers
+        .get(http::header::CONTENT_TYPE)
+        .and_then(|value| value.to_str().ok())
+        .is_some_and(|content_type| content_type.starts_with("text/event-stream"))
+}
+
+fn is_streaming_response(parts: &http::response::Parts) -> bool {
+    // Only SSE needs incremental gated filtering. HTTP/2 omits Content-Length for
+    // finite bodies; HTTP/1.1 may use chunked or close-delimited encoding without
+    // a Content-Length header. Those are fully collected before a single TPF check.
+    // Treating them as streaming misroutes through FilteredStreamBody and stalls clients.
+    is_sse_response(parts)
+}
+
+fn ensure_content_length(parts: &mut http::response::Parts, body_len: usize) {
+    if parts.headers.contains_key(http::header::CONTENT_LENGTH) {
+        return;
+    }
+    if let Ok(value) = http::HeaderValue::from_str(&body_len.to_string()) {
+        parts.headers.insert(http::header::CONTENT_LENGTH, value);
+    }
+}
