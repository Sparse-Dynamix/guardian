+/// Maximum bytes to peek when classifying a CONNECT tunnel (full TLS ClientHello record).
+const MAX_CONNECT_PEEK: usize = 4096;
+
+async fn peek_connect_protocol(tcp: &TcpStream) -> std::io::Result<(StreamProtocol, Bytes)> {
+    let mut buffer = [0u8; MAX_CONNECT_PEEK];
+    let mut idle_reads = 0u32;
+    const MAX_IDLE_READS: u32 = 200;
+
+    loop {
+        let filled = tcp.peek(&mut buffer).await?;
+        if filled > 0 {
+            let peeked = Bytes::copy_from_slice(&buffer[..filled]);
+            return Ok((classify_buffered_protocol(&peeked), peeked));
+        }
+        if idle_reads >= MAX_IDLE_READS {
+            break;
+        }
+        idle_reads += 1;
+        tokio::time::sleep(std::time::Duration::from_millis(5)).await;
+    }
+
+    Ok((StreamProtocol::Http, Bytes::new()))
+}
