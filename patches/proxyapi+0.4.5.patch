+#[cfg(test)]
+mod tests {
+    use super::*;
+    use openssl::x509::X509;
+
+    fn san_entries(cert: &X509) -> Vec<String> {
+        let san = cert
+            .subject_alt_names()
+            .expect("subjectAltName extension");
+        san.iter()
+            .map(|entry| {
+                let ty = entry.type_id();
+                if ty == openssl::nid::Nid::IPADDRESS {
+                    entry
+                        .ipaddress()
+                        .map(|bytes| {
+                            if bytes.len() == 4 {
+                                format!(
+                                    "{}.{}.{}.{}",
+                                    bytes[0], bytes[1], bytes[2], bytes[3]
+                                )
+                            } else {
+                                format!("{bytes:?}")
+                            }
+                        })
+                        .unwrap_or_else(|| entry.type_str().to_string())
+                } else {
+                    entry.dnsname().unwrap_or("").to_string()
+                }
+            })
+            .collect()
+    }
+
+    #[test]
+    fn gen_cert_uses_ip_san_for_literal_ipv4() {
+        let dir = tempfile::tempdir().unwrap();
+        let ssl = Ssl::load_or_generate(dir.path()).unwrap();
+        let authority: Authority = "127.0.0.2:443".parse().unwrap();
+        let der = ssl.gen_cert(&authority).unwrap();
+        let cert = X509::from_der(der.as_ref()).unwrap();
+
+        assert_eq!(san_entries(&cert), vec!["127.0.0.2"]);
+    }
+
+    #[test]
+    fn gen_cert_uses_dns_san_for_hostname() {
+        let dir = tempfile::tempdir().unwrap();
+        let ssl = Ssl::load_or_generate(dir.path()).unwrap();
+        let authority: Authority = "example.com:443".parse().unwrap();
+        let der = ssl.gen_cert(&authority).unwrap();
+        let cert = X509::from_der(der.as_ref()).unwrap();
+
+        assert_eq!(san_entries(&cert), vec!["example.com"]);
+    }
+}
