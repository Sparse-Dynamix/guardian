+use async_trait::async_trait;
+use bytes::Bytes;
+
+/// Context supplied when filtering an HTTP response body.
+pub struct HttpFilterContext<'a> {
+    pub method: &'a str,
+    pub url: &'a str,
+    pub status: u16,
+    pub scheme: &'a str,
+    pub body: &'a [u8],
+}
+
+/// Context supplied when filtering a WebSocket frame.
+pub struct WsFilterContext<'a> {
+    pub direction: &'a str,
+    pub opcode: &'a str,
+    pub payload: &'a [u8],
+}
+
+/// Decision returned by a content filter.
+#[derive(Debug)]
+pub enum FilterVerdict {
+    Allow,
+    Block {
+        message: Bytes,
+    },
+    Replace {
+        body: Bytes,
+        headers: http::HeaderMap,
+    },
+}
+
+/// Content filter used by embedded MITM paths before data reaches the client.
+#[async_trait]
+pub trait ContentFilter: Send + Sync {
+    async fn check_http_response(&self, ctx: HttpFilterContext<'_>) -> FilterVerdict;
+
+    async fn check_ws_frame(&self, ctx: WsFilterContext<'_>) -> FilterVerdict;
+}
